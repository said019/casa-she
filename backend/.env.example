# === Requeridas ===
DATABASE_URL=postgresql://usuario@localhost:5432/casa_she
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# Desactiva los cron jobs en desarrollo si no los necesitas
ENABLE_CRON_JOBS=false

# === Opcionales (cada feature se desactiva si falta su credencial) ===
# Pagos con tarjeta (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STATEMENT_DESCRIPTOR=CASA SHE

# Correos transaccionales (Resend)
RESEND_API_KEY=
EMAIL_FROM=Casa She <onboarding@resend.dev>

# Subida de comprobantes / media (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Check-in QR (firma de tokens) — definir uno fijo y NO rotarlo tras lanzar
CHECKIN_SECRET=casa-she-checkin-secret

# v1: deja en true para desactivar el envío automático de WhatsApp (usamos wa.me + email)
DISABLE_WHATSAPP=true
